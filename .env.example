# Neural Nexus Universal Memory Configuration

# API Server
PORT=3000
HOST=0.0.0.0
# Set an API key to enable security (X-API-Key header)
NEXUS_API_KEY=your_secret_key_here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=neural_nexus_universal
# QDRANT_API_KEY=

# LLM / Proxy Settings
OPENAI_PROXY_PORT=3001
LLM_TARGET_URL=http://localhost:11434/v1
# LLM_API_KEY=

# Core Logic Thresholds (Optional)
SIMILARITY_THRESHOLD=0.95
RECALL_THRESHOLD=0.1
DECAY_LAMBDA=1e-10
RRF_K=60

# Services
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
REPLACEMENT_LOG_PATH=./data/replacements.sqlite
REPLACEMENT_LOG_ENABLED=true

# Adapters
TELEGRAM_BOT_TOKEN=your_telegram_token

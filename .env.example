# Neural Nexus Universal Memory Configuration

# API Server
PORT=3000
HOST=0.0.0.0
# Set an API key to enable security (X-API-Key header)
NEXUS_API_KEY=your_secret_key_here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=neural_nexus_universal
# QDRANT_API_KEY=

# Embedding
# Xenova/bge-small-en-v1.5 is default
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Replacement Audit
REPLACEMENT_LOG_ENABLED=true
REPLACEMENT_LOG_PATH=./data/replacements.sqlite
